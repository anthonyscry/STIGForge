<UserControl x:Class="STIGForge.App.Views.WorkflowWizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:STIGForge.App">
    <Grid Margin="{DynamicResource AppPagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Step Indicator (data-driven) -->
        <Border Grid.Row="0"
                Margin="0,0,0,16"
                Padding="{DynamicResource CardPadding}"
                Background="{DynamicResource SurfaceMutedBrush}"
                BorderBrush="{DynamicResource BorderBrush}">
            <ItemsControl ItemsSource="{Binding WizardSteps}"
                          HorizontalAlignment="Center"
                          AutomationProperties.Name="Workflow step indicator">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:WizardStepInfo}">
                        <StackPanel Orientation="Horizontal">
                            <StackPanel Orientation="Horizontal" Margin="0,0,4,0">
                                <!-- Clickable step circle -->
                                <Border Width="26" Height="26" Margin="0,0,6,0" VerticalAlignment="Center"
                                        Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="13" />
                                            <Setter Property="BorderThickness" Value="2" />
                                            <Setter Property="SnapsToDevicePixels" Value="True" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFinalStep}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.Background>
                                        <MultiBinding Converter="{StaticResource StepActiveBackgroundConverter}">
                                            <Binding Path="DataContext.CurrentStep" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                            <Binding Path="Step"/>
                                            <Binding Path="IsFinalStep"/>
                                        </MultiBinding>
                                    </Border.Background>
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.GoToStepCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding Step}"/>
                                    </Border.InputBindings>
                                    <TextBlock Text="{Binding Number}" FontSize="12" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               IsHitTestVisible="False">
                                        <TextBlock.Foreground>
                                            <MultiBinding Converter="{StaticResource StepNumberForegroundConverter}">
                                                <Binding Path="DataContext.CurrentStep" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                <Binding Path="Step"/>
                                                <Binding Path="IsFinalStep"/>
                                            </MultiBinding>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                </Border>
                                <!-- Step label -->
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                            <Setter Property="FontWeight" Value="Normal" />
                                            <Style.Triggers>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{StaticResource StepMatchConverter}">
                                                            <Binding Path="DataContext.CurrentStep" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                            <Binding Path="Step"/>
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="FontWeight" Value="Bold" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <!-- Arrow separator (hidden for final step) -->
                            <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                       VerticalAlignment="Center" Margin="6,0"
                                       Foreground="{DynamicResource TextMutedBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFinalStep}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- Step Content -->
        <ContentControl Grid.Row="1" Content="{Binding}" Margin="0">
            <ContentControl.Style>
                <Style TargetType="ContentControl">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentStep}" Value="Setup">
                            <Setter Property="ContentTemplate" Value="{StaticResource SetupStepTemplate}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurrentStep}" Value="Import">
                            <Setter Property="ContentTemplate" Value="{StaticResource ImportStepTemplate}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurrentStep}" Value="Scan">
                            <Setter Property="ContentTemplate" Value="{StaticResource ScanStepTemplate}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurrentStep}" Value="Harden">
                            <Setter Property="ContentTemplate" Value="{StaticResource HardenStepTemplate}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurrentStep}" Value="Verify">
                            <Setter Property="ContentTemplate" Value="{StaticResource VerifyStepTemplate}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurrentStep}" Value="Done">
                            <Setter Property="ContentTemplate" Value="{StaticResource DoneStepTemplate}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ContentControl.Style>
        </ContentControl>

        <!-- Navigation Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="&#x2190; Back" Width="100" Height="36" Margin="0,0,10,0"
                    Style="{DynamicResource WorkflowDashboardButtonStyle}"
                    Command="{Binding GoBackCommand}"
                    IsEnabled="{Binding CanGoBack}"
                    AutomationProperties.Name="Go to previous step"
                    ToolTip="Return to the previous wizard step"/>
            <Button Content="Next &#x2192;" Width="100" Height="36"
                    Style="{DynamicResource WorkflowDashboardButtonStyle}"
                    Command="{Binding GoNextCommand}"
                    IsEnabled="{Binding CanGoNext}"
                    AutomationProperties.Name="Go to next step"
                    ToolTip="Proceed to the next wizard step"/>
        </StackPanel>
    </Grid>
</UserControl>
