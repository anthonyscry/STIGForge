<Window x:Class="STIGForge.App.Views.PreflightDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mission Pre-flight: Organizational Settings"
        Height="680"
        Width="880"
        MinHeight="520"
        MinWidth="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource WindowBackgroundBrush}">
  <Grid Margin="{DynamicResource AppPagePadding}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Border Grid.Row="0"
            Padding="{DynamicResource CardPadding}"
            Margin="0,0,0,12"
            Background="{DynamicResource SurfaceMutedBrush}"
            BorderBrush="{DynamicResource BorderBrush}">
      <StackPanel>
        <TextBlock Text="Mission Pre-flight" Style="{StaticResource PageTitleStyle}" />
        <TextBlock TextWrapping="Wrap"
                   Foreground="{DynamicResource TextMutedBrush}"
                   Margin="0,4,0,0"
                   Text="These organizational settings require site-specific values before hardening. Fill in the values below, or import a previously saved answer file." />
      </StackPanel>
    </Border>

    <!-- Summary + Import/Export -->
    <Grid Grid.Row="1" Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
        <TextBlock FontWeight="SemiBold" VerticalAlignment="Center">
          <TextBlock.Text>
            <MultiBinding StringFormat="{}{0} settings ({1} filled)">
              <Binding Path="TotalCount"/>
              <Binding Path="FilledCount"/>
            </MultiBinding>
          </TextBlock.Text>
        </TextBlock>
        <TextBlock Margin="16,0,0,0" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"
                   Text="{Binding HighSeverityCount, StringFormat='  {0} high severity'}"
                   Visibility="{Binding HasHighSeverity, Converter={StaticResource BoolToVisibility}}"/>
      </StackPanel>

      <StackPanel Grid.Column="1" Orientation="Horizontal">
        <Button Content="Import Answers" Width="130" Height="30" Margin="0,0,8,0"
                Click="Import_Click"
                AutomationProperties.Name="Import organizational settings from file"/>
        <Button Content="Export Answers" Width="130" Height="30"
                Click="Export_Click"
                AutomationProperties.Name="Export organizational settings to file"/>
      </StackPanel>
    </Grid>

    <!-- Category filter tabs -->
    <Border Grid.Row="2"
            BorderBrush="{DynamicResource BorderBrush}"
            Background="{DynamicResource SurfaceBrush}"
            CornerRadius="{DynamicResource UiPanelRadius}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Category filter -->
        <ItemsControl Grid.Row="0" ItemsSource="{Binding Categories}" Margin="8,8,8,4">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel Orientation="Horizontal"/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <ToggleButton Content="{Binding Name}"
                            IsChecked="{Binding IsSelected}"
                            Margin="0,0,6,4"
                            Padding="8,4"
                            MinWidth="80"
                            AutomationProperties.Name="{Binding Name, StringFormat='Filter by {0}'}"/>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Settings list -->
        <ListView Grid.Row="1" x:Name="SettingsList"
                  ItemsSource="{Binding FilteredEntries}"
                  Margin="4,0,4,4"
                  BorderThickness="0"
                  Background="Transparent"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  AutomationProperties.Name="Organizational settings list">
          <ListView.ItemContainerStyle>
            <Style TargetType="ListViewItem">
              <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
              <Setter Property="Padding" Value="4,6"/>
              <Setter Property="Margin" Value="0,1"/>
            </Style>
          </ListView.ItemContainerStyle>
          <ListView.ItemTemplate>
            <DataTemplate>
              <Border Padding="8,6"
                      BorderThickness="0,0,0,1"
                      BorderBrush="{DynamicResource BorderBrush}">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="250"/>
                  </Grid.ColumnDefinitions>

                  <!-- Rule ID -->
                  <TextBlock Grid.Column="0" Text="{Binding RuleId}"
                             FontWeight="SemiBold" FontFamily="Consolas"
                             VerticalAlignment="Center"/>

                  <!-- Severity badge -->
                  <Border Grid.Column="1" HorizontalAlignment="Left"
                          VerticalAlignment="Center"
                          CornerRadius="3" Padding="6,2" Margin="4,0">
                    <Border.Style>
                      <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource SurfaceMutedBrush}"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding Severity}" Value="high">
                            <Setter Property="Background" Value="#44DC3545"/>
                          </DataTrigger>
                          <DataTrigger Binding="{Binding Severity}" Value="medium">
                            <Setter Property="Background" Value="#44FFC107"/>
                          </DataTrigger>
                          <DataTrigger Binding="{Binding Severity}" Value="low">
                            <Setter Property="Background" Value="#44198754"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding Severity}" FontSize="11"
                               HorizontalAlignment="Center"/>
                  </Border>

                  <!-- Description -->
                  <TextBlock Grid.Column="2" Text="{Binding Description}"
                             TextWrapping="Wrap" VerticalAlignment="Center"
                             Foreground="{DynamicResource TextMutedBrush}"
                             Margin="8,0"/>

                  <!-- Value input -->
                  <TextBox Grid.Column="3" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                           Height="28" VerticalContentAlignment="Center"
                           ToolTip="{Binding Description}"
                           AutomationProperties.Name="{Binding RuleId, StringFormat='Value for {0}'}"/>
                </Grid>
              </Border>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </Grid>
    </Border>

    <!-- Profile name -->
    <Grid Grid.Row="3" Margin="0,8,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" Text="Profile Name:" FontWeight="SemiBold"
                 VerticalAlignment="Center" Margin="0,0,8,0"/>
      <TextBox Grid.Column="1" Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}"
               Height="28" VerticalContentAlignment="Center"
               AutomationProperties.Name="Answer file profile name"/>
    </Grid>

    <!-- Action buttons -->
    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button Content="Skip (use defaults)" Width="150" Height="32" Margin="0,0,8,0"
              Click="Skip_Click" IsCancel="True"
              AutomationProperties.Name="Skip pre-flight and use default values"/>
      <Button Content="Apply Settings" Width="130" Height="32"
              Click="Apply_Click" IsDefault="True"
              AutomationProperties.Name="Apply organizational settings and continue"/>
    </StackPanel>
  </Grid>
</Window>
