<Window x:Class="STIGForge.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:STIGForge.App.Views"
        Title="STIGForge" Height="600" Width="900" MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Window.InputBindings>
        <KeyBinding Key="R" Modifiers="Ctrl" Command="{Binding RunAutoWorkflowCommand}" />
        <KeyBinding Key="F1" Command="{Binding ShowHelpCommand}" />
        <KeyBinding Key="I" Modifiers="Alt" Command="{Binding RunImportStepCommand}" />
        <KeyBinding Key="S" Modifiers="Alt" Command="{Binding RunScanStepCommand}" />
        <KeyBinding Key="J" Modifiers="Alt" Command="{Binding SkipScanStepCommand}" />
        <KeyBinding Key="H" Modifiers="Alt" Command="{Binding RunHardenStepCommand}" />
        <KeyBinding Key="K" Modifiers="Alt" Command="{Binding SkipHardenStepCommand}" />
        <KeyBinding Key="V" Modifiers="Alt" Command="{Binding RunVerifyStepCommand}" />
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenOutputFolderCommand}" />
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding RestartWorkflowCommand}" />
    </Window.InputBindings>
    <Grid Margin="{DynamicResource AppPagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Margin="0,0,0,16"
                Padding="{DynamicResource CardPadding}"
                CornerRadius="12"
                Background="{DynamicResource SurfaceMutedBrush}"
                BorderBrush="{DynamicResource BorderBrush}">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="STIGForge"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}" />
                    <TextBlock Text="Build, apply, verify, prove"
                               Foreground="{DynamicResource TextMutedBrush}"
                               Margin="0,2,0,0" />
                </StackPanel>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                <ToggleButton Width="38" Height="38" Padding="0" Margin="0,0,8,0" TabIndex="899"
                              ToolTip="Toggle guided wizard mode"
                              IsChecked="{Binding IsWizardMode}"
                              Foreground="{DynamicResource TextBrush}"
                              AutomationProperties.Name="Guided wizard mode toggle"
                              AutomationProperties.AutomationId="wizard-mode-toggle">
                    <TextBlock Text="&#xE8CB;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                </ToggleButton>
                <Button Width="38" Height="38" Padding="0" Margin="0,0,8,0" TabIndex="900"
                        ToolTip="Help (F1)" Command="{Binding ShowHelpCommand}"
                        Foreground="{DynamicResource TextBrush}"
                        AutomationProperties.Name="Help" AutomationProperties.AutomationId="help-button">
                    <TextBlock Text="&#xE897;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                </Button>
                <Button Width="38" Height="38" Padding="0" Margin="0,0,8,0" TabIndex="901"
                        ToolTip="About" Command="{Binding ShowAboutCommand}"
                        Foreground="{DynamicResource TextBrush}"
                        AutomationProperties.Name="About" AutomationProperties.AutomationId="about-button">
                    <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                </Button>
                <Button Width="38" Height="38" Padding="0" TabIndex="902"
                        ToolTip="Settings" Command="{Binding ShowSettingsCommand}"
                        Foreground="{DynamicResource TextBrush}"
                        AutomationProperties.Name="Settings" AutomationProperties.AutomationId="settings-button">
                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                </Button>
            </StackPanel>
            </DockPanel>
        </Border>

        <!-- Dashboard (default) -->
        <views:DashboardView Grid.Row="1">
            <views:DashboardView.Style>
                <Style TargetType="UserControl">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsWizardMode}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </views:DashboardView.Style>
        </views:DashboardView>

        <!-- Guided Wizard (toggled) -->
        <views:WorkflowWizardView Grid.Row="1">
            <views:WorkflowWizardView.Style>
                <Style TargetType="UserControl">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsWizardMode}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </views:WorkflowWizardView.Style>
        </views:WorkflowWizardView>
    </Grid>
</Window>
