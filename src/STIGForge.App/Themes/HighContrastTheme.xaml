<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{x:Static SystemColors.WindowColor}"/>
  <SolidColorBrush x:Key="SurfaceBrush" Color="{x:Static SystemColors.ControlLightColor}"/>
  <SolidColorBrush x:Key="SurfaceMutedBrush" Color="{x:Static SystemColors.ControlColor}"/>
  <SolidColorBrush x:Key="BorderBrush" Color="{x:Static SystemColors.ActiveBorderColor}"/>
  <SolidColorBrush x:Key="TextPrimaryBrush" Color="{x:Static SystemColors.WindowTextColor}"/>
  <SolidColorBrush x:Key="TextMutedBrush" Color="{x:Static SystemColors.GrayTextColor}"/>
  <SolidColorBrush x:Key="AccentBrush" Color="{x:Static SystemColors.HighlightColor}"/>
  <SolidColorBrush x:Key="AccentSoftBrush" Color="{x:Static SystemColors.ControlLightColor}"/>
  <SolidColorBrush x:Key="SuccessBrush" Color="{x:Static SystemColors.WindowTextColor}"/>
  <SolidColorBrush x:Key="WarningBrush" Color="{x:Static SystemColors.InfoTextColor}"/>
  <SolidColorBrush x:Key="DangerBrush" Color="{x:Static SystemColors.HotTrackColor}"/>
  <SolidColorBrush x:Key="WorkflowStepReadyBrush" Color="{x:Static SystemColors.HighlightColor}"/>
  <SolidColorBrush x:Key="WorkflowStepRunningBrush" Color="{x:Static SystemColors.InfoTextColor}"/>
  <SolidColorBrush x:Key="WorkflowStepCompleteBrush" Color="{x:Static SystemColors.WindowTextColor}"/>
  <SolidColorBrush x:Key="WorkflowStepLockedBrush" Color="{x:Static SystemColors.GrayTextColor}"/>
  <SolidColorBrush x:Key="WorkflowStepErrorBrush" Color="{x:Static SystemColors.HotTrackColor}"/>

  <!-- Button -->
  <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="{x:Static SystemColors.ControlColor}"/>
  <SolidColorBrush x:Key="ButtonHoverBrush" Color="{x:Static SystemColors.HighlightColor}"/>
  <SolidColorBrush x:Key="ButtonPressedBrush" Color="{x:Static SystemColors.ControlDarkColor}"/>
  <SolidColorBrush x:Key="ButtonDisabledBgBrush" Color="{x:Static SystemColors.ControlLightColor}"/>
  <SolidColorBrush x:Key="ButtonDisabledBorderBrush" Color="{x:Static SystemColors.ControlDarkColor}"/>
  <SolidColorBrush x:Key="ButtonDisabledFgBrush" Color="{x:Static SystemColors.GrayTextColor}"/>

  <!-- TabItem -->
  <SolidColorBrush x:Key="TabBgBrush" Color="{x:Static SystemColors.ControlLightColor}"/>
  <SolidColorBrush x:Key="TabSelectedBgBrush" Color="{x:Static SystemColors.WindowColor}"/>
  <SolidColorBrush x:Key="TabHoverBgBrush" Color="{x:Static SystemColors.ControlColor}"/>
  <SolidColorBrush x:Key="TabPanelBgBrush" Color="{x:Static SystemColors.WindowColor}"/>

  <!-- ComboBox / Dropdown -->
  <SolidColorBrush x:Key="ComboBoxBgBrush" Color="{x:Static SystemColors.ControlColor}"/>
  <SolidColorBrush x:Key="ComboBoxPopupBgBrush" Color="{x:Static SystemColors.WindowColor}"/>
  <SolidColorBrush x:Key="ComboBoxItemHoverBrush" Color="{x:Static SystemColors.ControlLightColor}"/>
  <SolidColorBrush x:Key="ComboBoxArrowBrush" Color="{x:Static SystemColors.GrayTextColor}"/>

  <!-- ListViewItem -->
  <SolidColorBrush x:Key="ListItemHoverBrush" Color="{x:Static SystemColors.ControlColor}"/>
  <SolidColorBrush x:Key="ListItemSelectedBrush" Color="{x:Static SystemColors.HighlightColor}"/>
  <SolidColorBrush x:Key="ListItemSelectedTextBrush" Color="{x:Static SystemColors.HighlightTextColor}"/>
  <SolidColorBrush x:Key="GridViewHeaderBgBrush" Color="{x:Static SystemColors.ControlLightColor}"/>
  <SolidColorBrush x:Key="GridViewHeaderBorderBrush" Color="{x:Static SystemColors.ActiveBorderColor}"/>

  <!-- ScrollBar -->
  <SolidColorBrush x:Key="ScrollThumbBrush" Color="{x:Static SystemColors.ControlDarkColor}"/>
  <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="{x:Static SystemColors.ControlDarkDarkColor}"/>
  <SolidColorBrush x:Key="ScrollTrackBrush" Color="{x:Static SystemColors.ControlLightColor}"/>
  <SolidColorBrush x:Key="ScrollArrowBrush" Color="{x:Static SystemColors.WindowTextColor}"/>

  <!-- Help dialog -->
  <SolidColorBrush x:Key="HelpSectionBrush" Color="{x:Static SystemColors.WindowColor}"/>
  <SolidColorBrush x:Key="HelpSectionAltBrush" Color="{x:Static SystemColors.ControlLightColor}"/>
  <SolidColorBrush x:Key="HelpBorderBrush" Color="{x:Static SystemColors.ActiveBorderColor}"/>

  <!-- ToolTip -->
  <SolidColorBrush x:Key="ToolTipBgBrush" Color="{x:Static SystemColors.InfoColor}"/>
  <SolidColorBrush x:Key="ToolTipBorderBrush" Color="{x:Static SystemColors.ActiveBorderColor}"/>

  <!-- Visual effects -->
  <Color x:Key="CardShadowColor">{x:Static SystemColors.WindowTextColor}</Color>

</ResourceDictionary>
